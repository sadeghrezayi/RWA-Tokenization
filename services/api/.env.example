# Copy to .env for local development. Matches docker-compose.yml at the repo root.
DATABASE_URL="postgresql://tokenization:tokenization@localhost:5433/tokenization"
PORT=3001

# Auth (FR-ID-1/FR-ID-4). Generate the officer hash with:
#   node -e "require('argon2').hash(process.argv[1]).then(console.log)" 'your-password'
AUTH_TOKEN_SECRET="change-me-long-random-string"
OFFICER_EMAIL="officer@platform.local"
OFFICER_PASSWORD_HASH=

# Devnet claim issuance (all three required to enable the ONCHAINID adapter;
# leave unset to fall back to the logging placeholder).
# The mnemonic below is the WELL-KNOWN anvil/hardhat test mnemonic — devnet only.
DEVNET_RPC_URL="http://127.0.0.1:8545"
PLATFORM_OPERATOR_MNEMONIC="test test test test test test test test test test test junk"
# Printed by the contracts deploy script (contracts/, forge script Deploy):
ONCHAINID_CLAIM_ISSUER_ADDRESS=
