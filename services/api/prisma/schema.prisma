generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Tenancy (OD-1a): single-tenant install on a tenant-ready schema. Every
// tenant-owned row carries tenant_id (FK to tenants). Scoping is enforced by
// the composition root (TenantContext + scoped Prisma extension), never
// trusted from client input. The "default" tenant is seeded by migration.
// ---------------------------------------------------------------------------

model Tenant {
  id        String   @id
  name      String
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")

  organizations         Organization[]
  tokenTransfers        TokenTransfer[]
  redemptions           Redemption[]
  attestations          Attestation[]
  assets                Asset[]
  assetDocuments        AssetDocument[]
  assetEvents           AssetEvent[]
  distributions         Distribution[]
  distributionPayouts   DistributionPayout[]
  offerings             Offering[]
  offeringSubscriptions OfferingSubscription[]
  offeringAllocations   OfferingAllocation[]
  ledgerAccounts        LedgerAccount[]
  ledgerEntries         LedgerEntry[]
  investorWallets       InvestorWallet[]
  investors             Investor[]
  onchainIdentities     OnchainIdentity[]
  crmProfiles           CrmProfile[]
  crmNotes              CrmNote[]
  crmFollowUps          CrmFollowUp[]

  @@map("tenants")
}

// Organizations under a tenant: the platform operator itself, issuers, asset
// owners, and service providers. Lifecycle/workflow arrives with the issuer
// portal (Phase 3); the table exists now for schema stability.
model Organization {
  id        String   @id
  tenantId  String   @default("default") @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  type      String
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("organizations")
}

enum KycState {
  draft
  submitted
  in_review
  approved
  rejected
  expired
}

enum AssetState {
  proposed
  in_structuring
  approved
  tokenized
  suspended
  retired
}

// FR-TR-1: executed compliant transfers (feeds the holder registry + history).
model TokenTransfer {
  id             String   @id
  tenantId       String   @default("default") @map("tenant_id")
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  assetId        String   @map("asset_id")
  tokenAddress   String   @map("token_address")
  fromInvestorId String   @map("from_investor_id")
  toInvestorId   String   @map("to_investor_id")
  tokens         BigInt
  executedAt     DateTime @map("executed_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([assetId])
  @@index([fromInvestorId])
  @@index([toInvestorId])
  @@map("token_transfers")
}

enum RedemptionState {
  requested
  fulfilled
  rejected
}

// FR-TR-2: redemption requests and their resolution at attested value.
model Redemption {
  id              String          @id
  tenantId        String          @default("default") @map("tenant_id")
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  assetId         String          @map("asset_id")
  tokenAddress    String          @map("token_address")
  investorId      String          @map("investor_id")
  tokens          BigInt
  state           RedemptionState
  requestedAt     DateTime        @map("requested_at")
  payoutRial      BigInt?         @map("payout_rial")
  rejectionReason String?         @map("rejection_reason")
  resolvedAt      DateTime?       @map("resolved_at")
  createdAt       DateTime        @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([investorId])
  @@map("redemptions")
}

enum AttestationKind {
  valuation
  nav
  rent
  reserve
}

// FR-OR: signed real-world facts about an asset, hash anchored on-chain.
model Attestation {
  id          String          @id
  tenantId    String          @default("default") @map("tenant_id")
  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  assetId     String          @map("asset_id")
  kind        AttestationKind
  valueRial   BigInt          @map("value_rial")
  attestorId  String          @map("attestor_id")
  issuedAt    DateTime        @map("issued_at")
  validUntil  DateTime        @map("valid_until")
  payloadHash String          @map("payload_hash")
  signature   String
  documentCid String?         @map("document_cid")
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([assetId, kind, issuedAt])
  @@map("attestations")
}

model Asset {
  id              String          @id
  tenantId        String          @default("default") @map("tenant_id")
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  name            String
  type            String
  state           AssetState
  custodianName   String?         @map("custodian_name")
  custodyLocation String?         @map("custody_location")
  tokenAddress    String?         @map("token_address")
  checklist       String[]
  documents       AssetDocument[]
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("assets")
}

model AssetDocument {
  id        String   @id @default(uuid())
  tenantId  String   @default("default") @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  assetId   String   @map("asset_id")
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  kind      String
  title     String
  cid       String
  sha256    String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("asset_documents")
}

// FR-AO-5 / seed of FR-RA-2: append-only audit trail of asset actions.
model AssetEvent {
  id        BigInt   @id @default(autoincrement())
  tenantId  String   @default("default") @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  assetId   String   @map("asset_id")
  event     String
  actor     String
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("asset_events")
}

enum DistributionState {
  declared
  paid
}

model Distribution {
  id              String               @id
  tenantId        String               @default("default") @map("tenant_id")
  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  assetId         String               @map("asset_id")
  tokenAddress    String               @map("token_address")
  totalAmountRial BigInt               @map("total_amount_rial")
  state           DistributionState
  payouts         DistributionPayout[]
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("distributions")
}

model DistributionPayout {
  id             BigInt       @id @default(autoincrement())
  tenantId       String       @default("default") @map("tenant_id")
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  distributionId String       @map("distribution_id")
  distribution   Distribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  investorId     String       @map("investor_id")
  tokens         BigInt
  amountRial     BigInt       @map("amount_rial")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("distribution_payouts")
}

enum OfferingState {
  draft
  open
  closed_success
  closed_failed
}

model Offering {
  id             String                 @id
  tenantId       String                 @default("default") @map("tenant_id")
  tenant         Tenant                 @relation(fields: [tenantId], references: [id])
  assetId        String                 @map("asset_id")
  tokenAddress   String                 @map("token_address")
  supply         BigInt
  priceRial      BigInt                 @map("price_rial")
  minPerInvestor BigInt                 @map("min_per_investor")
  maxPerInvestor BigInt                 @map("max_per_investor")
  minimumRaise   BigInt                 @map("minimum_raise")
  opensAt        DateTime               @map("opens_at")
  closesAt       DateTime               @map("closes_at")
  state          OfferingState
  subscriptions  OfferingSubscription[]
  allocations    OfferingAllocation[]
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("offerings")
}

model OfferingSubscription {
  id         BigInt   @id @default(autoincrement())
  tenantId   String   @default("default") @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  offeringId String   @map("offering_id")
  offering   Offering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  investorId String   @map("investor_id")
  tokens     BigInt
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("offering_subscriptions")
}

model OfferingAllocation {
  id         BigInt   @id @default(autoincrement())
  tenantId   String   @default("default") @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  offeringId String   @map("offering_id")
  offering   Offering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  investorId String   @map("investor_id")
  requested  BigInt
  allocated  BigInt
  costRial   BigInt   @map("cost_rial")
  refundRial BigInt   @map("refund_rial")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("offering_allocations")
}

// D3: off-chain Rial ledger. Balance columns are the fast path; the
// append-only entries are the auditable record (NFR-2).
model LedgerAccount {
  investorId String   @id @map("investor_id")
  tenantId   String   @default("default") @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  balance    BigInt   @default(0)
  held       BigInt   @default(0)
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("ledger_accounts")
}

model LedgerEntry {
  id         BigInt   @id @default(autoincrement())
  tenantId   String   @default("default") @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  investorId String   @map("investor_id")
  kind       String
  amountRial BigInt   @map("amount_rial")
  actor      String
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("ledger_entries")
}

// FR-CU-1 custodial wallets: HD-derived per investor from the platform key.
// Addresses stay globally unique (chain reality); derivation index is global.
model InvestorWallet {
  derivationIndex Int    @id @default(autoincrement()) @map("derivation_index")
  tenantId        String @default("default") @map("tenant_id")
  tenant          Tenant @relation(fields: [tenantId], references: [id])
  investorId      String @unique @map("investor_id")
  address         String @unique

  @@index([tenantId])
  @@map("investor_wallets")
}

model Investor {
  id                 String           @id
  tenantId           String           @default("default") @map("tenant_id")
  tenant             Tenant           @relation(fields: [tenantId], references: [id])
  email              String
  passwordHash       String           @map("password_hash")
  kycState           KycState         @map("kyc_state")
  kycRejectionReason String?          @map("kyc_rejection_reason")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  onchainIdentity    OnchainIdentity?

  @@unique([tenantId, email])
  @@map("investors")
}

// Adapter-owned mapping: which ONCHAINID identity contract belongs to which
// investor. Chain-infrastructure detail, deliberately outside the domain model.
model OnchainIdentity {
  investorId String   @id @map("investor_id")
  tenantId   String   @default("default") @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  address    String   @unique
  createdAt  DateTime @default(now()) @map("created_at")
  investor   Investor @relation(fields: [investorId], references: [id])

  @@index([tenantId])
  @@map("onchain_identities")
}

model CrmProfile {
  investorId String   @id @map("investor_id")
  tenantId   String   @default("default") @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  stage      String
  tags       String[]
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("crm_profiles")
}

model CrmNote {
  id         String   @id
  tenantId   String   @default("default") @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  investorId String   @map("investor_id")
  authorId   String   @map("author_id")
  text       String
  createdAt  DateTime @map("created_at")

  @@index([tenantId])
  @@map("crm_notes")
}

model CrmFollowUp {
  id         String    @id
  tenantId   String    @default("default") @map("tenant_id")
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  investorId String    @map("investor_id")
  text       String
  dueAt      DateTime  @map("due_at")
  state      String
  doneAt     DateTime? @map("done_at")
  createdAt  DateTime  @map("created_at")

  @@index([tenantId])
  @@map("crm_follow_ups")
}
