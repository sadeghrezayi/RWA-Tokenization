{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    "resolveJsonModule": true,
    // NestJS runs CJS with legacy decorators; verbatimModuleSyntax would force
    // `import = require` syntax in CJS files, so it is disabled for this package.
    "verbatimModuleSyntax": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src", "test", "vitest.config.ts", "vitest.integration.config.ts"]
}
