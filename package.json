{
  "name": "tokenization-platform",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "esbuild",
      "@swc/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma"
